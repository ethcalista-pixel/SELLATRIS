-- ── Preview dummy ─────────────────────────────────────────────────────────────
local previewDummy  = nil
local previewJoints = {}
local uniqueJoints  = {}
local camAngle      = math.rad(180)

local function buildPreviewDummy()
	if previewDummy then previewDummy:Destroy(); previewDummy = nil end
	previewJoints = {}
	uniqueJoints  = {}

	if not player:HasAppearanceLoaded() then
		player.CharacterAppearanceLoaded:Wait()
	end
	task.wait(0.2)

	local char = player.Character
	if not char then return end

	char.Archivable = true
	local clone = char:Clone()
	char.Archivable = false

	for _, v in pairs(clone:GetDescendants()) do
		if v:IsA("Script") or v:IsA("LocalScript") then v:Destroy() end
	end

	clone.Parent = worldModel
	clone:PivotTo(CFrame.new(0, 0, 0))
	previewDummy = clone

	local seenMotors = {}
	for _, v in pairs(clone:GetDescendants()) do
		if v:IsA("Motor6D") then
			local entry = { motor=v, origC0=v.C0 }
			if v.Part1 and not previewJoints[v.Part1.Name] then
				previewJoints[v.Part1.Name] = entry
			end
			if not previewJoints[v.Name] then
				previewJoints[v.Name] = entry
			end
			if not seenMotors[v] then
				seenMotors[v] = true
				local key = (v.Part1 and v.Part1.Name) or v.Name
				table.insert(uniqueJoints, { partName=key, entry=entry })
			end
		end
	end
end

-- ── Preview playback ──────────────────────────────────────────────────────────
local previewAnim    = nil
local previewElapsed = 0
local previewActive  = false
local previewToken   = 0
local jointCursors   = {}

local function resetAllJoints()
	for _, item in ipairs(uniqueJoints) do
		local e = item.entry
		if e.motor and e.motor.Parent then e.motor.C0 = e.origC0 end
	end
end

local function startPreview(cat, animName)
	previewActive = false; previewAnim = nil; previewElapsed = 0; jointCursors = {}
	previewLbl.Visible = false
	if not previewDummy then buildPreviewDummy() end

	previewToken += 1
	local myToken = previewToken
	task.spawn(function()
		local anim = loadAnim(cat, animName)
		if previewToken ~= myToken then return end
		if not anim then previewLbl.Text = "no data"; previewLbl.Visible = true; return end
		for _, name in ipairs(anim.joints) do jointCursors[name] = 1 end
		previewAnim = anim; previewElapsed = 0; previewActive = true
	end)
end

local function stopPreview()
	previewToken += 1
	previewActive = false; previewAnim = nil; previewElapsed = 0; jointCursors = {}
	resetAllJoints()
	previewLbl.Text = "hover to preview"; previewLbl.Visible = true
end

