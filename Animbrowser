-- ── Easing ────────────────────────────────────────────────────────────────────
local function bounceOut(t)
	local n, d = 7.5625, 2.75
	if     t < 1/d   then return n*t*t
	elseif t < 2/d   then t = t-1.5/d;  return n*t*t+0.75
	elseif t < 2.5/d then t = t-2.25/d; return n*t*t+0.9375
	else                   t = t-2.625/d; return n*t*t+0.984375
	end
end
local function easeIn(t, s)
	if s == "Constant" then return 0 end
	if s == "Cubic"    then return t*t*t end
	if s == "Bounce"   then return 1-bounceOut(1-t) end
	if s == "Elastic"  then
		if t == 0 then return 0 end; if t == 1 then return 1 end
		return -(math.pow(2,10*t-10)*math.sin((t*10-10.75)*(2*math.pi/3)))
	end
	return t
end
local function easeOut(t, s)
	if s == "Constant" then return 1 end
	if s == "Bounce"   then return bounceOut(t) end
	if s == "Elastic"  then
		if t == 0 then return 0 end; if t == 1 then return 1 end
		return math.pow(2,-10*t)*math.sin((t*10-0.75)*(2*math.pi/3))+1
	end
	return 1-easeIn(1-t, s)
end
local function applyEasing(t, es, ed)
	es = es or "Linear"; ed = ed or "Out"
	if es == "Linear" then return t end
	if ed == "In"     then return easeIn(t, es) end
	if ed == "Out"    then return easeOut(t, es) end
	if t < 0.5 then return easeIn(t*2, es)*0.5 end
	return easeOut((t-0.5)*2, es)*0.5+0.5
end

-- ── Animation loader ──────────────────────────────────────────────────────────
local animCache = {}

local function loadAnim(cat, animName)
	animCache[cat] = animCache[cat] or {}
	if animCache[cat][animName] then return animCache[cat][animName] end

	local catFolder = animsRoot:FindFirstChild(cat)
	if not catFolder then return nil end
	local mod = catFolder:FindFirstChild(animName)
	if not mod or not mod:IsA("ModuleScript") then return nil end

	local ok, raw = pcall(require, mod)
	if not ok or type(raw) ~= "table" then return nil end

	local timeline, jointSet, duration = {}, {}, 0

	for _, keyframe in ipairs(raw) do
		if type(keyframe) ~= "table" then continue end
		local t = keyframe.tm
		if type(t) ~= "number" then continue end
		if t > duration then duration = t end
		for partName, data in pairs(keyframe) do
			if partName == "tm" or type(data) ~= "table" then continue end
			local cf = data.cf
			if typeof(cf) ~= "CFrame" then continue end
			if not timeline[partName] then timeline[partName] = {}; jointSet[partName] = true end
			table.insert(timeline[partName], { t=t, cf=cf, es=data.es or "Linear", ed=data.ed or "Out" })
		end
	end

	for _, tl in pairs(timeline) do
		table.sort(tl, function(a, b) return a.t < b.t end)
	end

	local joints = {}
	for name in pairs(jointSet) do table.insert(joints, name) end
	table.sort(joints)

	if #joints == 0 then return nil end

	local anim = { duration=duration, joints=joints, timeline=timeline }
	animCache[cat][animName] = anim
	return anim
end

