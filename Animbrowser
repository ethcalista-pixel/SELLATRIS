local function populateCategory(catName)
	for _, child in pairs(animScroll:GetChildren()) do
		if child:IsA("GuiObject") then child:Destroy() end
	end
	local catFolder = animsRoot:WaitForChild(catName, 10)
	if not catFolder then return end
	local children = waitForChildren(catFolder, 5)
	local mods = {}
	for _, child in ipairs(children) do
		if child:IsA("ModuleScript") then table.insert(mods, child) end
	end
