-- ── Render loop ───────────────────────────────────────────────────────────────
RunService.RenderStepped:Connect(function(dt)
	panelBg.Rotation = (panelBg.Rotation + dt*5) % 360

	for _, p in ipairs(particles) do
		p.y -= p.speed * dt
		if p.y < -0.1 then p.y = 1.08; p.baseX = rng:NextNumber(0, 1) end
		p.gui.Position = UDim2.new(p.baseX + math.sin(tick()*p.freq+p.seed)*p.amp, 0, p.y, 0)
	end

	-- Preview also respects the speed slider so hovering shows the correct tempo
	if previewActive and previewAnim and previewDummy then
		local anim     = previewAnim
		local duration = anim.duration
		local spd      = math.max(animSpeedValue.Value, 0)

		previewElapsed += dt * spd
		if duration > 0 and previewElapsed >= duration then
			previewElapsed = previewElapsed % duration
			for _, name in ipairs(anim.joints) do jointCursors[name] = 1 end
		end

		local t = previewElapsed

		for _, item in ipairs(uniqueJoints) do
			local partName = item.partName
			local entry    = item.entry
			if not entry.motor or not entry.motor.Parent then continue end

			local tl = anim.timeline[partName]
			if not tl then entry.motor.C0 = entry.origC0; continue end

			local motor = entry.motor
			local n     = #tl

			if t <= tl[1].t then motor.C0 = entry.origC0 * tl[1].cf; continue end
			if t >= tl[n].t then motor.C0 = entry.origC0 * tl[n].cf; continue end

			local cursor = jointCursors[partName] or 1
			while cursor < n-1 and tl[cursor+1].t <= t do cursor += 1 end
			jointCursors[partName] = cursor

			local kA, kB = tl[cursor], tl[cursor+1]
			local span   = kB.t - kA.t
			local raw    = (span > 0) and math.clamp((t-kA.t)/span, 0, 1) or 0
			motor.C0 = entry.origC0 * kA.cf:Lerp(kB.cf, applyEasing(raw, kA.es, kA.ed))
		end
	end

	if previewDummy then
		local hrp = previewDummy:FindFirstChild("HumanoidRootPart")
		if hrp then
			local offset = CFrame.Angles(0, camAngle, 0) * CFrame.new(0, 0, CAM_DIST)
			vpCam.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 0.5, 0)) * offset
		end
	end
end)
