local function spawnSmear(cx, cy, rot, alpha)
	local s = Instance.new("ImageLabel")
	s.Image                  = IMAGE_ID
	s.Size                   = UDim2.fromOffset(LOGO_SIZE * 3.2, LOGO_SIZE * 0.55)
	s.AnchorPoint            = Vector2.new(0.5, 0.5)
	s.Position               = UDim2.new(0, cx, 0, cy)
	s.BackgroundTransparency = 1
	s.ImageTransparency      = math.clamp(1 - alpha, 0, 1)
	s.Rotation               = rot
	s.ScaleType              = Enum.ScaleType.Fit
	s.ZIndex                 = 9
	s.Parent                 = screenGui

	TweenService:Create(s, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1,
		Size = UDim2.fromOffset(LOGO_SIZE * 4.5, LOGO_SIZE * 0.12),
	}):Play()

	task.delay(0.22, function()
		if s and s.Parent then s:Destroy() end
	end)
end

