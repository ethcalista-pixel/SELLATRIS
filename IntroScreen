-- ─────────────────────────────────────────────────────────
--  Helpers
-- ─────────────────────────────────────────────────────────
local function tw(obj, info, props)
	local t = TweenService:Create(obj, info, props); t:Play(); return t
end
local function twWait(obj, info, props)
	local t = TweenService:Create(obj, info, props); t:Play(); t.Completed:Wait()
end
local function corner(obj, r)
	Instance.new("UICorner", obj).CornerRadius = UDim.new(0, r or 8)
end
local function stroke(obj, col, thick)
	local s = Instance.new("UIStroke")
	s.Color = col; s.Thickness = thick or 1.5
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj; return s
end

