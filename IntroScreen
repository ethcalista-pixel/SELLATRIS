--  TITLE  "SELLATRIS" — per-letter labels for hover bounce
-- ═══════════════════════════════════════════════════════════
local TITLE_LEFT   = LOGO_SIZE + 32
local TITLE_FONT   = Enum.Font.GothamBlack
local TITLE_SIZE   = 82
local BOUNCE_DIST  = 14   -- px upward on hover

-- Container frame — positioned like the old single label
local titleContainer = Instance.new("Frame")
titleContainer.Name                   = "TitleContainer"
titleContainer.Size                   = UDim2.fromOffset(600, TITLE_SIZE + BOUNCE_DIST + 8)
titleContainer.AnchorPoint            = Vector2.new(0, 0.5)
titleContainer.Position               = UDim2.new(0, TITLE_LEFT, 0.5, 0)
titleContainer.BackgroundTransparency = 1
titleContainer.ClipsDescendants       = false
titleContainer.ZIndex                 = 9
titleContainer.Parent                 = screenGui

local titleLayout = Instance.new("UIListLayout")
titleLayout.FillDirection         = Enum.FillDirection.Horizontal
titleLayout.HorizontalAlignment   = Enum.HorizontalAlignment.Left
titleLayout.VerticalAlignment     = Enum.VerticalAlignment.Bottom
titleLayout.Padding               = UDim.new(0, 0)
titleLayout.SortOrder             = Enum.SortOrder.LayoutOrder
titleLayout.Parent                = titleContainer

-- Build one label + padding per letter
local LETTERS      = { "S","E","L","L","A","T","R","I","S" }
local letterLabels = {}   -- { label, padding, stroke, bouncing }
local titleStroke  = nil  -- set to first letter's stroke for compat; all strokes stored in letterLabels

for i, char in ipairs(LETTERS) do
	local lbl = Instance.new("TextLabel")
	lbl.Name                   = "Letter_"..i
	lbl.BackgroundTransparency = 1
	lbl.Text                   = char
	lbl.Font                   = TITLE_FONT
	lbl.TextSize               = TITLE_SIZE
	lbl.TextColor3             = T.Text
	lbl.TextTransparency       = 1
	lbl.AutomaticSize          = Enum.AutomaticSize.X
	lbl.Size                   = UDim2.fromOffset(0, TITLE_SIZE + BOUNCE_DIST + 8)
	lbl.LayoutOrder            = i
	lbl.ZIndex                 = 9
	lbl.Parent                 = titleContainer

	local pad = Instance.new("UIPadding")
	pad.PaddingTop    = UDim.new(0, BOUNCE_DIST + 4)  -- letters sit at resting baseline
	pad.PaddingBottom = UDim.new(0, 0)
	pad.Parent        = lbl

	local st = Instance.new("UIStroke")
	st.Color        = T.Accent
	st.Thickness    = 2.5
	st.Transparency = 1
	st.Parent       = lbl

	if i == 1 then titleStroke = st end  -- keep compat reference

	local entry = { label = lbl, padding = pad, stroke = st, bouncing = false }
	letterLabels[i] = entry

	-- Hover bounce — only active after title is revealed (guarded by bouncing flag)
	lbl.MouseEnter:Connect(function()
		if lbl.TextTransparency > 0.5 then return end
		if entry.bouncing then return end
		entry.bouncing = true
		TweenService:Create(pad,
			TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ PaddingTop = UDim.new(0, 0) }   -- bounce up
		):Play()
		TweenService:Create(lbl,
			TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ TextColor3 = T.AccentBright }
		):Play()
	end)
	lbl.MouseLeave:Connect(function()
		entry.bouncing = false
		TweenService:Create(pad,
			TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{ PaddingTop = UDim.new(0, BOUNCE_DIST + 4) }   -- spring back down
		):Play()
		TweenService:Create(lbl,
			TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ TextColor3 = T.Text }
		):Play()
	end)
end

-- Helpers: tween all letters together (used for reveal / dismiss)
local function setAllLettersTransparency(transparency, tweenInfo)
	for _, e in ipairs(letterLabels) do
		TweenService:Create(e.label, tweenInfo, { TextTransparency = transparency }):Play()
	end
end
local function setAllStrokesTransparency(transparency, tweenInfo)
	for _, e in ipairs(letterLabels) do
		TweenService:Create(e.stroke, tweenInfo, { Transparency = transparency }):Play()
	end
end
local function setAllStrokesColor(color, tweenInfo)
	for _, e in ipairs(letterLabels) do
		TweenService:Create(e.stroke, tweenInfo, { Color = color }):Play()
	end
end

