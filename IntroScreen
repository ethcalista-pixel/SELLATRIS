local function easeOutQuad(t) return 1 - (1 - t) * (1 - t) end

local FLY_TIME       = 0.50
local vp             = workspace.CurrentCamera.ViewportSize
local startX, startY = vp.X * 0.5, vp.Y * 0.5
local endX,   endY   = LOGO_SIZE / 2 + 16, vp.Y * 0.5
local flyElapsed     = 0
local smearTimer     = 0
local SMEAR_RATE     = 0.022
local haloFlyAngle   = haloAngle
local glowFlyAngle   = glowAngle

-- Red flash on shoot
tw(flashFrame, TweenInfo.new(0.07), { BackgroundTransparency = 0.72 })
task.delay(0.07, function()
	tw(flashFrame, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 })
end)
safePlay(sWhoosh)

-- Fade flames + vignette
tw(flameCanvas, TweenInfo.new(FLY_TIME * 1.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	{ GroupTransparency = 1 })
tw(vigCanvas,   TweenInfo.new(FLY_TIME * 1.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	{ GroupTransparency = 1 })
tw(bgBase,      TweenInfo.new(FLY_TIME * 1.8, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	{ BackgroundColor3 = T.Panel })

-- Particles pivot to rightward drift
dirBlendTarget = 1

-- Title fades in mid-fly
local _titleFlyInfo = TweenInfo.new(FLY_TIME * 0.85, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, 0, false, FLY_TIME * 0.3)
setAllLettersTransparency(0,   _titleFlyInfo)
setAllStrokesTransparency(0.2, _titleFlyInfo)

local flyConn
flyConn = RunService.Heartbeat:Connect(function(dt)
	flyElapsed    = flyElapsed + dt
	local t       = math.clamp(flyElapsed / FLY_TIME, 0, 1)
	local et      = easeOutQuad(t)

	local cx = startX + (endX - startX) * et
	local cy = startY + (endY - startY) * et

	logoImage.Position = UDim2.new(0, cx, 0, cy)
	haloRing.Position  = UDim2.new(0, cx, 0, cy)
	logoGlow.Position  = UDim2.new(0, cx, 0, cy)

	spinAngle      = spinAngle      + dt * 160
	haloFlyAngle   = haloFlyAngle   - dt * 110
	glowFlyAngle   = glowFlyAngle   + dt * 18
	logoImage.Rotation = (spinAngle    + (-90 * et)) % 360
	haloRing.Rotation  = haloFlyAngle  % 360
	logoGlow.Rotation  = glowFlyAngle  % 360

	-- Smears
	if t < 0.80 then
		smearTimer = smearTimer + dt
		if smearTimer >= SMEAR_RATE then
			smearTimer = 0
			spawnSmear(cx, cy, logoImage.Rotation, 0.92 - (t * 0.45))
		end
	end

	if t >= 1 then
		flyConn:Disconnect()
		logoImage.Position = UDim2.new(0, endX, 0, endY)
		haloRing.Position  = UDim2.new(0, endX, 0, endY)
		logoGlow.Position  = UDim2.new(0, endX, 0, endY)

		-- Impact flash
		safePlay(sImpact)
		tw(flashFrame, TweenInfo.new(0.06), { BackgroundTransparency = 0.80 })
		task.delay(0.06, function()
			tw(flashFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
				{ BackgroundTransparency = 1 })
		end)

		-- Shockwave
		shockwave.Position = UDim2.new(0, endX, 0, endY)
		shockwave.Size     = UDim2.fromOffset(0, 0)
		shockwave.ImageTransparency = 0.15
		TweenService:Create(shockwave, TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = UDim2.fromOffset(520, 520), ImageTransparency = 1,
		}):Play()

		-- Halo tightens then pulses gently
		tw(haloRing, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.fromOffset(LOGO_SIZE + 32, LOGO_SIZE + 32), ImageTransparency = 0.30,
		})
		task.delay(0.25, function()
			TweenService:Create(haloRing,
				TweenInfo.new(1.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
				{ ImageTransparency = 0.65, Size = UDim2.fromOffset(LOGO_SIZE + 48, LOGO_SIZE + 48) }
			):Play()
		end)

		-- Glow pulses behind the logo
		TweenService:Create(logoGlow,
			TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
			{ ImageTransparency = 0.45, Size = UDim2.fromOffset(LOGO_SIZE * 2.4, LOGO_SIZE * 2.4) }
		):Play()

		-- Title: slide in from right + underline sweep + subtitle
		task.delay(0.08, function()
			safePlay(sSting)
			local _ri = TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			titleLabel.Position = UDim2.new(0, TITLE_LEFT + 45, 0.5, 0)
			tw(titleLabel, _ri, { Position = UDim2.new(0, TITLE_LEFT, 0.5, 0) })
			setAllLettersTransparency(0,    _ri)
			setAllStrokesTransparency(0.15, _ri)

			task.delay(0.18, function()
				tw(titleUnderline,
					TweenInfo.new(0.40, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
					{ Size = UDim2.fromOffset(460, 3) })
			end)
			task.delay(0.35, function()
				tw(subtitleLabel,
					TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
					{ TextTransparency = 0 })
			end)
			task.delay(0.55, function()
				setAllStrokesColor(T.AccentBright,
					TweenInfo.new(2.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true))
			end)

			task.delay(0.20, function()
				for _, f in ipairs(bracketParts) do
					tw(f, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
						{ BackgroundTransparency = 0.4 })
				end
			end)
		end)

		-- Idle spin after landing
		local idleConn
		idleConn = RunService.Heartbeat:Connect(function(dt2)
			spinAngle    = spinAngle    + dt2 * 55
			haloFlyAngle = haloFlyAngle - dt2 * 30
			glowFlyAngle = glowFlyAngle + dt2 * 10
			logoImage.Rotation = spinAngle    % 360
			haloRing.Rotation  = haloFlyAngle % 360
			logoGlow.Rotation  = glowFlyAngle % 360
		end)

		-- ── PHASE 3 — reveal PLAY ──────────────────────
		task.delay(0.35, function()

			twWait(bgBase,
				TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
				{ BackgroundTransparency = 0.50 })

			-- Button slides up from below into left-aligned position
			tw(playButton,
				TweenInfo.new(0.60, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
				{ Position = UDim2.new(0, LOGO_SIZE + 32, 1, -52), BackgroundTransparency = 0.55 })

			task.delay(0.10, function()
				tw(playButton,
					TweenInfo.new(0.30, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
					{ TextTransparency = 0 })
				tw(playStroke,
					TweenInfo.new(0.30, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
					{ Transparency = 0 })
			end)

			task.wait(0.75)

			-- Stroke slowly breathes between accent and bright
			TweenService:Create(playStroke,
				TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
				{ Color = T.AccentBright }):Play()

			-- Hover: slight fill + text brightens
			playButton.MouseEnter:Connect(function()
				safePlay(sHover)
				tw(playButton, TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
					{ Size = UDim2.fromOffset(162, 44), BackgroundTransparency = 0.30,
						TextColor3 = T.Text })
				tw(playStroke, TweenInfo.new(0.12),
					{ Color = T.AccentBright, Thickness = 2 })
			end)
			playButton.MouseLeave:Connect(function()
				tw(playButton, TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
					{ Size = UDim2.fromOffset(150, 40), BackgroundTransparency = 0.55,
						TextColor3 = T.AccentBright })
				tw(playStroke, TweenInfo.new(0.18),
					{ Color = T.Accent, Thickness = 1.5 })
			end)

			_G._introIdleConn = idleConn
		end)
	end
end)

