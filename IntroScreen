local sounds = {}
local function makeSound(id, volume, looped)
	local s        = Instance.new("Sound")
	s.SoundId      = id
	s.Volume       = volume
	s.Looped       = looped or false
	s.Parent       = SoundService
	sounds[#sounds + 1] = s
	return s
end

local sAmbient = makeSound(SFX.AmbientMusic.id, SFX.AmbientMusic.vol, true)
local sWhoosh  = makeSound(SFX.WhooshShoot.id,  SFX.WhooshShoot.vol,  false)
local sImpact  = makeSound(SFX.LandImpact.id,   SFX.LandImpact.vol,   false)
local sSting   = makeSound(SFX.TitleSting.id,   SFX.TitleSting.vol,   false)
local sHover   = makeSound(SFX.ButtonHover.id,  SFX.ButtonHover.vol,  false)
local sClick   = makeSound(SFX.ButtonClick.id,  SFX.ButtonClick.vol,  false)

local function safePlay(s)
	if s and s.SoundId ~= "rbxassetid://0" and s.SoundId ~= "" then
		s:Play()
	end
end

local function fadeOutAllSounds(duration)
	for _, s in ipairs(sounds) do
		if s and s.Parent then
			TweenService:Create(s,
				TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
				{ Volume = 0 }):Play()
		end
	end
end

