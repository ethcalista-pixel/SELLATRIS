--  PHASE 1 — Spinning star + flames  (fake load)
-- ═══════════════════════════════════════════════════════════
local spinAngle  = 0
local haloAngle  = 0
local glowAngle  = 0
local flickTimer = 0
local dotTimer   = 0
local DOT_CYCLE  = 0.45   -- seconds per dot step

local spinConn = RunService.Heartbeat:Connect(function(dt)
	spinAngle = spinAngle + dt * 55
	haloAngle = haloAngle - dt * 35
	glowAngle = glowAngle + dt * 12
	logoImage.Rotation  = spinAngle % 360
	haloRing.Rotation   = haloAngle % 360
	logoGlow.Rotation   = glowAngle % 360

	-- Pulse the glow size slightly
	local pulse = 1 + 0.06 * math.sin(tick() * 3.5)
	local gs = LOGO_SIZE * 2 * pulse
	logoGlow.Size = UDim2.fromOffset(gs, gs)
end)

local flickConn = RunService.Heartbeat:Connect(function(dt)
	flickTimer = flickTimer + dt
	local flicker = 0.06 * math.sin(flickTimer * 7.3)
		+ 0.04 * math.sin(flickTimer * 13.1 + 1.2)
	flameCanvas.GroupTransparency = math.clamp(flicker, 0, 0.12)

	-- Animated loading dots
	dotTimer = dotTimer + dt
	if dotTimer >= DOT_CYCLE then
		dotTimer = dotTimer - DOT_CYCLE
		for i, dot in ipairs(loadDots) do
			local active = (math.floor(tick() / DOT_CYCLE) % 3) + 1 == i
			TweenService:Create(dot, TweenInfo.new(0.15),
				{ BackgroundTransparency = active and 0 or 0.72,
					Size = active and UDim2.fromOffset(13, 13) or UDim2.fromOffset(9, 9) }
			):Play()
		end
	end
end)

local particleConn = RunService.Heartbeat:Connect(function(dt)
	dirBlend = dirBlend + (dirBlendTarget - dirBlend) * math.min(dt * DIR_BLEND_SPEED, 1)
	local t = tick()
	for _, p in ipairs(particles) do
		p.y = p.y - p.speed * (1 - dirBlend) * dt
		p.x = p.x + p.speed * 0.85 * dirBlend * dt
		if p.y < -0.06 then p.y = 1.05; p.baseX = rng:NextNumber(0,1); p.x = p.baseX end
		if p.x >  1.06 then p.x = -0.05; p.baseY = rng:NextNumber(0,1); p.y = p.baseY end
		local wobble = math.sin(t * p.freq + p.seed) * p.amp
		local px = p.baseX + wobble * (1 - dirBlend) + p.x * dirBlend
		local py = p.y * (1 - dirBlend) + p.baseY + wobble * dirBlend
		p.gui.Position = UDim2.new(px, 0, py, 0)
	end
end)

