-- Render loop
local grainTimer = 0
RunService.RenderStepped:Connect(function(dt)
	panelBg.Rotation = (panelBg.Rotation + dt*5) % 360
	for _, p in ipairs(particles) do
		p.y -= p.speed * dt
		if p.y < -0.1 then p.y=1.08; p.baseX=rng:NextNumber(0,1) end
		p.gui.Position = UDim2.new(p.baseX + math.sin(tick()*p.freq+p.seed)*p.amp, 0, p.y, 0)
	end
	if grainIntensity > 0.01 then
		grainTimer += dt
		if grainTimer >= 0.05 then
			grainTimer = 0
			for _, d in ipairs(grainDots) do
				d.Position = UDim2.new(rngGrain:NextNumber(0,1),0,rngGrain:NextNumber(0,1),0)
				d.BackgroundTransparency = rngGrain:NextNumber(0.2,0.85)
			end
		end
	end
end)
