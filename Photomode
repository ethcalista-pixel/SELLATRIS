local function sld(label, minV, maxV, defV, fmt, order, onChange)
	local row=mk("Frame",scroll,{Size=UDim2.new(1,0,0,52),BackgroundTransparency=1,ZIndex=32,LayoutOrder=order})

	local header=mk("Frame",row,{Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,ZIndex=32})
	mk("TextLabel",header,{
		Size=UDim2.new(1,-44,1,0),BackgroundTransparency=1,Text=label,
		TextColor3=T.TextMuted,TextSize=8,Font=Enum.Font.GothamBold,
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=33,
		TextTransparency=0,
	})
	local vLbl=mk("TextLabel",header,{
		Size=UDim2.new(0,42,1,0),Position=UDim2.new(1,-42,0,0),
		BackgroundTransparency=1,Text=string.format(fmt,defV),
		TextColor3=T.AccentBright,TextSize=9,Font=Enum.Font.GothamBlack,
		TextXAlignment=Enum.TextXAlignment.Right,ZIndex=33,
	})

	-- Outer track shell
	local shell=mk("Frame",row,{
		Size=UDim2.new(1,0,0,28),Position=UDim2.new(0,0,0,20),
		BackgroundColor3=Color3.fromRGB(7,3,3),ZIndex=32,
	})
	corner(shell,6)
	mk("UIStroke",shell,{Color=Color3.fromRGB(40,18,18),Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border})

	-- Rail (thin line inside shell)
	local rail=mk("Frame",shell,{
		Size=UDim2.new(1,-16,0,2),Position=UDim2.new(0,8,0.5,-1),
		BackgroundColor3=Color3.fromRGB(45,18,18),ZIndex=33,
	})
	corner(rail,1)

	-- Filled portion of rail
	local defA=math.clamp((defV-minV)/(maxV-minV),0,1)
	local railFill=mk("Frame",rail,{
		Size=UDim2.new(defA,0,1,0),BackgroundColor3=T.Accent,ZIndex=34,
	})
	corner(railFill,1)
	mk("UIGradient",railFill,{
		Color=ColorSequence.new{
			ColorSequenceKeypoint.new(0, T.AccentDeep),
			ColorSequenceKeypoint.new(0.5, T.AccentDark),
			ColorSequenceKeypoint.new(1, T.AccentBright),
		},
		Rotation=0,
	})

	-- Notch knob (vertical accent bar, no circle)
	local notchGlow=mk("Frame",shell,{
		Size=UDim2.new(0,10,1,-4),Position=UDim2.new(defA,-5,0,2),
		BackgroundColor3=T.Accent,BackgroundTransparency=0.72,ZIndex=34,
	})
	corner(notchGlow,4)
	local notch=mk("Frame",shell,{
		Size=UDim2.new(0,4,1,-10),Position=UDim2.new(defA,-2,0,5),
		BackgroundColor3=Color3.new(1,1,1),ZIndex=35,
	})
	corner(notch,2)
	mk("UIGradient",notch,{
		Color=ColorSequence.new{
			ColorSequenceKeypoint.new(0, T.AccentBright),
			ColorSequenceKeypoint.new(1, T.Accent),
		},
		Rotation=90,
	})

	-- Invisible full-size drag button over shell
	local hitbox=mk("TextButton",shell,{
		Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=36,
	})

	local function setA(a)
		a=math.clamp(a,0,1)
		railFill.Size     = UDim2.new(a,0,1,0)
		notchGlow.Position= UDim2.new(a,-5,0,2)
		notch.Position    = UDim2.new(a,-2,0,5)
		local v=minV+(maxV-minV)*a
		vLbl.Text=string.format(fmt,v)
		TweenService:Create(notch,TS_FAST,{BackgroundTransparency=0}):Play()
		onChange(v)
	end

	hitbox.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 then
			local a=math.clamp((inp.Position.X-shell.AbsolutePosition.X)/shell.AbsoluteSize.X,0,1)
			setA(a); dragging={track=shell,set=setA}
			TweenService:Create(notchGlow,TS_FAST,{BackgroundTransparency=0.45}):Play()
		end
	end)
	hitbox.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 then
			TweenService:Create(notchGlow,TS_FAST,{BackgroundTransparency=0.72}):Play()
		end
	end)
	hitbox.MouseEnter:Connect(function()
		TweenService:Create(notchGlow,TS_FAST,{BackgroundTransparency=0.55}):Play()
		TweenService:Create(vLbl,TS_FAST,{TextColor3=T.Text}):Play()
	end)
	hitbox.MouseLeave:Connect(function()
		TweenService:Create(notchGlow,TS_FAST,{BackgroundTransparency=0.72}):Play()
		TweenService:Create(vLbl,TS_FAST,{TextColor3=T.AccentBright}):Play()
	end)

	table.insert(sliderResets, function() setA(defA) end)
	return setA
end

local function tog(label, default, order, onChange)
	local row=mk("Frame",scroll,{Size=UDim2.new(1,0,0,36),BackgroundColor3=T.ItemBg,ZIndex=32,LayoutOrder=order})
	corner(row,8); stroke(row,T.Stroke,1)
	mk("TextLabel",row,{
		Size=UDim2.new(1,-58,1,0),Position=UDim2.new(0,10,0,0),
		BackgroundTransparency=1,Text=label,
		TextColor3=T.TextDim,TextSize=9,Font=Enum.Font.GothamBold,
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=33,
	})
	local pill=mk("Frame",row,{Size=UDim2.new(0,44,0,22),Position=UDim2.new(1,-50,0.5,-11),BackgroundColor3=Color3.fromRGB(10,5,5),ZIndex=33})
	corner(pill,11); stroke(pill,T.Stroke,1)
	local knob=mk("Frame",pill,{Size=UDim2.new(0,18,0,18),Position=UDim2.new(0,2,0.5,-9),BackgroundColor3=T.TextMuted,ZIndex=34})
	corner(knob,9)
	local btn=mk("TextButton",row,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=35})
	local state=false
	local function setOn(v)
		state=v
		TweenService:Create(knob,TS_FAST,{
			Position=v and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9),
			BackgroundColor3=v and T.Accent or T.TextMuted,
		}):Play()
		TweenService:Create(pill,TS_FAST,{BackgroundColor3=v and T.AccentDeep or Color3.fromRGB(10,5,5)}):Play()
		onChange(v)
	end
	btn.MouseButton1Click:Connect(function() setOn(not state) end)
	if default then task.defer(function() setOn(true) end) end
	table.insert(sliderResets, function() if state ~= default then setOn(default) end end)
	return setOn
end

