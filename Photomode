local function applyFreecamUI(active)
	if active then
		TweenService:Create(fcBtn,    TS_FAST,{BackgroundColor3=T.ItemActive}):Play()
		TweenService:Create(fcStr,    TS_FAST,{Color=T.Accent}):Play()
		TweenService:Create(fcLbl,    TS_FAST,{TextColor3=T.Text}):Play()
		TweenService:Create(fcDot,    TS_FAST,{BackgroundColor3=T.AccentBright}):Play()
		TweenService:Create(fcStatus, TS_FAST,{TextColor3=T.Green}):Play()
		fcStatus.Text="ACTIVE"
	else
		TweenService:Create(fcBtn,    TS_FAST,{BackgroundColor3=T.ItemBg}):Play()
		TweenService:Create(fcStr,    TS_FAST,{Color=T.Stroke}):Play()
		TweenService:Create(fcLbl,    TS_FAST,{TextColor3=T.TextDim}):Play()
		TweenService:Create(fcDot,    TS_FAST,{BackgroundColor3=T.AccentDark}):Play()
		TweenService:Create(fcStatus, TS_FAST,{TextColor3=T.TextMuted}):Play()
		fcStatus.Text="OFF"
	end
end

