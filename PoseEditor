function setLimbSelection(limbName)
	if selectedLimbBtn then
		TweenService:Create(selectedLimbBtn, TS_FAST, {BackgroundColor3=T.ItemBg}):Play()
		local os = selectedLimbBtn:FindFirstChildWhichIsA("UIStroke")
		if os then TweenService:Create(os,TS_FAST,{Color=T.Stroke}):Play() end
		local lbl2 = selectedLimbBtn:FindFirstChildWhichIsA("TextLabel")
		if lbl2 then TweenService:Create(lbl2,TS_FAST,{TextColor3=T.TextDim}):Play() end
	end
	selectedLimb    = limbName
	selectedLimbBtn = limbBtnMap[limbName]
	if selectedLimbBtn then
		TweenService:Create(selectedLimbBtn, TS_FAST, {BackgroundColor3=T.ItemActive}):Play()
		local s = selectedLimbBtn:FindFirstChildWhichIsA("UIStroke")
		if s then TweenService:Create(s,TS_FAST,{Color=T.Accent}):Play() end
		local lbl2 = selectedLimbBtn:FindFirstChildWhichIsA("TextLabel")
		if lbl2 then TweenService:Create(lbl2,TS_FAST,{TextColor3=T.Text}):Play() end
	end
	if limbName then
		selLbl.Text       = limbName:upper()
		selLbl.TextColor3 = T.AccentBright
		for _, ld in ipairs(LIMBS_DEF) do
			if ld.name == limbName then selDot.BackgroundColor3 = ld.dotCol; break end
		end
		spawnHandles(limbName)
	else
		selLbl.Text             = "NONE"
		selLbl.TextColor3       = T.TextMuted
		selDot.BackgroundColor3 = T.TextMuted
		destroyHandles()
	end
end

