-- ── buildLimbPreviews ─────────────────────────────────────────────────────────
local function buildLimbPreviews()
	if not player:HasAppearanceLoaded() then
		player.CharacterAppearanceLoaded:Wait()
	end
	task.wait(0.2)

	local char = player.Character
	if not char then return end

	for _, ld in ipairs(LIMBS_DEF) do
		local vp = vpPreviews[ld.name]
		if not vp then continue end

		for _, c in ipairs(vp.wm:GetChildren()) do
			if c.Name ~= "LightPart" then c:Destroy() end
		end
		vp.part = nil

		char.Archivable = true
		local clone = char:Clone()
		char.Archivable = false

		for _, v in ipairs(clone:GetDescendants()) do
			if v:IsA("Script") or v:IsA("LocalScript") then
				v:Destroy()
			elseif v:IsA("BasePart") then
				if v.Name == "HumanoidRootPart" or v.Transparency == 1 or v.Parent:IsA("Accessory") then
					v.CanQuery = false
				else
					v.CanQuery = true
				end
			end
		end

		clone.Parent = vp.wm
		clone:PivotTo(CFrame.new(0, 0, 0))

		local targetPart = clone:FindFirstChild(ld.name)
		if not targetPart then continue end

		local function isWeldedToTarget(accHandle)
			for _, w in ipairs(accHandle:GetChildren()) do
				if w:IsA("Weld") or w:IsA("WeldConstraint") then
					local p0 = w.Part0; local p1 = w.Part1
					if p0 == targetPart or p1 == targetPart then return true end
				end
			end
			return false
		end

		for _, v in ipairs(clone:GetDescendants()) do
			if v:IsA("BasePart") then
				local isTarget = (v == targetPart)
				local isAccOnTarget = v.Parent:IsA("Accessory") and isWeldedToTarget(v)
				if not isTarget and not isAccOnTarget then
					v.Transparency = 1
					for _, ch in ipairs(v:GetChildren()) do
						if ch:IsA("Decal") or ch:IsA("Texture") then ch.Transparency = 1 end
					end
				end
			end
		end

		local hrp = clone:FindFirstChild("HumanoidRootPart")
		if hrp then hrp.Transparency = 1 end

		vp.part = targetPart
		local sz = targetPart.Size
		local maxD = math.max(sz.X, sz.Y, sz.Z)
		vp.camDist   = maxD * 2.0 + 1.2
		vp.camTarget = targetPart.Position
	end
end


