-- ── Helpers ───────────────────────────────────────────────────────────────────
local function cacheOriginals()
	local char = player.Character; if not char then return end
	originalC0s = {}
	for _, ld in ipairs(LIMBS_DEF) do
		local pp = char:FindFirstChild(ld.parent)
		if pp then
			local m = pp:FindFirstChild(ld.joint)
			if m and m:IsA("Motor6D") then originalC0s[ld.name] = m.C0 end
		end
	end
end

local function getMotor(limbName)
	local char = player.Character; if not char then return nil end
	for _, ld in ipairs(LIMBS_DEF) do
		if ld.name == limbName then
			local pp = char:FindFirstChild(ld.parent)
			if pp then
				local m = pp:FindFirstChild(ld.joint)
				if m and m:IsA("Motor6D") then return m end
			end
		end
	end
end

local function getAdornPart(limbName)
	local char = player.Character; if not char then return nil end
	if limbName == "Torso" then
		return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
	end
	return char:FindFirstChild(limbName)
end

local function getPart1(limbName)
	local char = player.Character; if not char then return nil end
	if limbName == "Torso" then return char:FindFirstChild("Torso") end
	return char:FindFirstChild(limbName)
end

-- ── Animations ────────────────────────────────────────────────────────────────
local function setAnimationsEnabled(enabled)
	local char = player.Character; if not char then return end
	local hum  = char:FindFirstChildWhichIsA("Humanoid"); if not hum then return end
	local anim = char:FindFirstChild("Animate")
	if anim then anim.Disabled = not enabled end
	local animator = hum:FindFirstChildWhichIsA("Animator")
	if animator then
		for _, t in ipairs(animator:GetPlayingAnimationTracks()) do t:Stop(0) end
	end
end

-- ── Anchor ────────────────────────────────────────────────────────────────────
local function setAnchored(state)
	isAnchored = state
	anchorRemote:FireServer(state)
	if state then
		setAnimationsEnabled(false)
