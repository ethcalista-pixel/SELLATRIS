--  STATIC HANDLES
-- ═══════════════════════════════════════════════════════════════════════════
function destroyHandles()
	if currentArcH   then currentArcH:Destroy();   currentArcH   = nil end
	if currentMovH   then currentMovH:Destroy();   currentMovH   = nil end
	if currentSelBox then currentSelBox:Destroy(); currentSelBox = nil end
end

local function spawnHandles(limbName)
	destroyHandles()
	if not limbName then return end

	local adorn = getAdornPart(limbName)
	local part1 = getPart1(limbName)
	local motor = getMotor(limbName)
	if not adorn or not part1 or not motor then return end

	local sb = mk("SelectionBox", gui, {
		Adornee=adorn, Color3=T.Accent,
		LineThickness=0.04, SurfaceTransparency=0.85, SurfaceColor3=T.Accent,
	})
	currentSelBox = sb

	if handleMode == "Rotate" then
		local ah = mk("ArcHandles", gui, {
			Adornee = adorn,
			Axes    = Axes.new(Enum.Axis.X, Enum.Axis.Y, Enum.Axis.Z),
		})
		currentArcH = ah

		local startCF = nil
		ah.MouseButton1Down:Connect(function(_)
			startCF = part1.CFrame
		end)
		ah.MouseDrag:Connect(function(axis, angle)
			if not startCF then return end
			local worldAxis
			if      axis == Enum.Axis.X then worldAxis =  startCF.RightVector
			elseif  axis == Enum.Axis.Y then worldAxis =  startCF.UpVector
			else                             worldAxis = -startCF.LookVector
			end
			local pos  = startCF.Position
			local piv  = CFrame.new(pos)
			local wRot = piv * CFrame.fromAxisAngle(worldAxis, angle) * piv:Inverse()
			motor.C0   = motor.Part0.CFrame:Inverse() * (wRot * startCF) * motor.C1
		end)
		ah.MouseButton1Up:Connect(function(_)
			poseData[limbName] = motor.C0; startCF = nil
		end)

	else
		local mh = mk("Handles", gui, {
			Adornee = adorn,
			Faces   = Faces.new(Enum.NormalId.Front, Enum.NormalId.Back,
				Enum.NormalId.Left, Enum.NormalId.Right,
				Enum.NormalId.Top,  Enum.NormalId.Bottom),
			Style = Enum.HandlesStyle.Movement,
		})
		currentMovH = mh

		local startP1CF  = nil
		local faceNormal = nil

		mh.MouseButton1Down:Connect(function(face)
			startP1CF = part1.CFrame
			local cf  = adorn.CFrame
			local map = {
				[Enum.NormalId.Right]  =  cf.RightVector,
				[Enum.NormalId.Left]   = -cf.RightVector,
				[Enum.NormalId.Top]    =  cf.UpVector,
				[Enum.NormalId.Bottom] = -cf.UpVector,
				[Enum.NormalId.Front]  =  cf.LookVector,
				[Enum.NormalId.Back]   = -cf.LookVector,
			}
			faceNormal = map[face] or Vector3.new(0,1,0)
		end)
		mh.MouseDrag:Connect(function(_, dist)
			if not startP1CF then return end
			local newPos   = startP1CF.Position + faceNormal * dist
			local newPart1 = CFrame.new(newPos)
				* CFrame.fromMatrix(Vector3.zero, startP1CF.XVector, startP1CF.YVector)
			motor.C0 = motor.Part0.CFrame:Inverse() * newPart1 * motor.C1
		end)
		mh.MouseButton1Up:Connect(function(_)
			poseData[limbName] = motor.C0; startP1CF = nil; faceNormal = nil
		end)
	end
end

