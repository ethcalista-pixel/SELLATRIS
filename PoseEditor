-- ═══════════════════════════════════════════════════════════════════════════
--  RENDER LOOP
-- ═══════════════════════════════════════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
	-- Particles
	for _, p in ipairs(particles) do
		p.y -= p.speed * dt
		if p.y < -0.1 then p.y=1.08; p.baseX=rng:NextNumber(0,1) end
		p.gui.Position = UDim2.new(p.baseX + math.sin(tick()*p.freq+p.seed)*p.amp, 0, p.y, 0)
	end

	-- Spin viewport preview cameras
	for _, vp in pairs(vpPreviews) do
		if vp.part and vp.cam then
			vp.angle = (vp.angle or 0) + dt * 0.9
			local dist   = vp.camDist   or 3
			local target = vp.camTarget or Vector3.zero
			local camPos = Vector3.new(
				target.X + math.sin(vp.angle) * dist,
				target.Y + dist * 0.3,
				target.Z + math.cos(vp.angle) * dist
			)
			vp.cam.CFrame = CFrame.lookAt(camPos, target)
		end
	end

end)
