-- ── Helpers ───────────────────────────────────────────────────────────────────
local function mk(cls, parent, props)
	local i = Instance.new(cls)
	if parent then i.Parent = parent end
	if props  then for k,v in pairs(props) do i[k] = v end end
	return i
end
local function corner(p, r)
	return mk("UICorner", p, {CornerRadius = UDim.new(0, r or 8)})
end
local function stroke(p, col, thick)
	return mk("UIStroke", p, {Color=col or T.Stroke, Thickness=thick or 1,
		ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
end
local function grad(p, c0, c1, rot)
	return mk("UIGradient", p, {
		Color    = ColorSequence.new{ColorSequenceKeypoint.new(0,c0), ColorSequenceKeypoint.new(1,c1)},
		Rotation = rot or 90,
	})
end
local function makePill(parent, h)
	local f = mk("Frame", parent, {
		Size             = UDim2.new(1,0,0,h),
		BackgroundColor3 = Color3.fromRGB(10,5,5), ZIndex=32,
	})
	corner(f,11); stroke(f,T.Stroke,1)
	return f
end
local function pillSlider(parent)
	local s = mk("Frame", parent, {
		Size=UDim2.new(0.5,-2,1,-4), Position=UDim2.new(0,2,0,2),
		BackgroundColor3=T.AccentDark, ZIndex=33,
	})
	corner(s,8); grad(s,T.Accent,T.AccentDark,90); return s
end
local function pillLabel(parent, txt, side)
	return mk("TextLabel", parent, {
		Size             = UDim2.new(0.5,0,1,0),
		Position         = side=="right" and UDim2.new(0.5,0,0,0) or UDim2.new(0,0,0,0),
		BackgroundTransparency=1, Text=txt,
		TextColor3       = side=="right" and T.TextMuted or T.Text,
		TextSize=9, Font=Enum.Font.GothamBlack, ZIndex=34,
	})
end

