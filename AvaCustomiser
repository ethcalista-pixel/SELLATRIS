local function getCategory(partName)
	if partName == "Torso"     then return "Torso"    end
	if partName == "Left Arm"  then return "LeftArm"  end
	if partName == "Right Arm" then return "RightArm" end
	if partName == "Left Leg"  then return "LeftLeg"  end
	if partName == "Right Leg" then return "RightLeg" end
	return nil
end

local function triggerGlowFlash(part)
	local glow = part:Clone()
	glow.Name = "GlowShell"
	for _, child in pairs(glow:GetChildren()) do
		if child:IsA("SpecialMesh") or child:IsA("BlockMesh") or child:IsA("CylinderMesh") then
			child.TextureId = ""
		else
			child:Destroy()
		end
	end
	if glow:IsA("MeshPart") then glow.TextureID = "" end
	glow.Size         = part.Size + Vector3.new(0.06, 0.06, 0.06)
	glow.CFrame       = part.CFrame
	glow.Material     = Enum.Material.Neon
	glow.Color        = THEME.Accent
	glow.Transparency = 0.2
	glow.CanQuery     = false
	glow.CanCollide   = false
	glow.Anchored     = false
	glow.Parent       = part.Parent
	local wc = Instance.new("WeldConstraint")
	wc.Part0 = part; wc.Part1 = glow; wc.Parent = glow
	local fade = TweenService:Create(glow,
		TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
		{Transparency = 1, Size = part.Size}
	)
	fade:Play()
	fade.Completed:Connect(function() glow:Destroy() end)
end

local function getViewportRay(viewportFrame, cam, inputPos)
	local sz  = viewportFrame.AbsoluteSize
	local lp  = inputPos - viewportFrame.AbsolutePosition
	local nx  = (lp.X - sz.X/2) / (sz.X/2)
	local ny  = (sz.Y/2 - lp.Y) / (sz.Y/2)
	local fov = math.rad(cam.FieldOfView)
	local tan = math.tan(fov/2)
	local ar  = sz.X / sz.Y
	local dir = cam.CFrame:VectorToWorldSpace(Vector3.new(nx*tan*ar, ny*tan, -1)).Unit
	return cam.CFrame.Position, dir
end

vpf.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		if not dragMoved then
			local origin, dir = getViewportRay(vpf, camera, Vector2.new(input.Position.X, input.Position.Y))
			local params = RaycastParams.new()
			params.FilterType = Enum.RaycastFilterType.Include
			params.FilterDescendantsInstances = {dummy}
			local result = worldModel:Raycast(origin, dir * 1000, params)
			if result and result.Instance then
				local cat = getCategory(result.Instance.Name)
				if cat then
					triggerGlowFlash(result.Instance)
					setExpandedState(true, cat)
				else
					setExpandedState(false)
				end
			else
				setExpandedState(false)
			end
		end
	end
end)

