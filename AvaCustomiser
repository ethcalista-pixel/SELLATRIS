-- ═══════════════════════════════════════════════════
--  RENDER LOOP  (particles, camera, IK)
-- ═══════════════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
	panelBg.Rotation = (panelBg.Rotation + dt * 6) % 360

	for _, p in ipairs(particles) do
		p.y -= p.speed * dt
		if p.y < -0.08 then
			p.y     = 1.06
			p.baseX = rng:NextNumber(0, 1)
		end
		local xOff = math.sin(tick() * p.freq + p.seed) * p.amp
		p.gui.Position = UDim2.new(p.baseX + xOff, 0, p.y, 0)
	end

	local deltaCam = targetCamAngleX - currentCamAngleX
	currentCamAngleX += deltaCam * math.min(dt * 14, 1)
	currentCameraDistance += (targetCameraDistance - currentCameraDistance) * math.min(dt * 14, 1)

	local swingTarget = isAnimEnabled and (deltaCam * SWING_INPUT_MULT) or 0
	currentSwingAngle += (swingTarget - currentSwingAngle) * math.min(dt * SWING_SPEED, 1)

	for motor, origC0 in pairs(originalC0s) do
		if motor.Parent then
			if motor.Name == "Left Shoulder" or motor.Name == "Right Shoulder" then
				local isLeft = motor.Name:match("Left")
				local sign   = isLeft and 1 or -1
				local pitch  = currentSwingAngle * ARM_PITCH_MULT * sign
				local roll   = math.abs(currentSwingAngle) * ARM_ROLL_MULT * (isLeft and -1 or 1)
				motor.C0 = CFrame.new(origC0.Position)
					* CFrame.Angles(pitch, 0, roll)
					* (origC0 - origC0.Position)
			elseif motor.Name == "RootJoint" then
				local yawLag   = currentSwingAngle * TORSO_YAW_MULT
				local rollLean = currentSwingAngle * TORSO_ROLL_MULT
				motor.C0 = CFrame.new(origC0.Position)
					* CFrame.Angles(0, yawLag, rollLean)
					* (origC0 - origC0.Position)
			elseif motor.Name == "Neck" then
				local counterYaw = -currentSwingAngle * HEAD_COUNTER_YAW
				motor.C0 = CFrame.new(origC0.Position)
					* CFrame.Angles(0, counterYaw, 0)
					* (origC0 - origC0.Position)
			end
		end
	end

	if dummy and dummy:FindFirstChild("HumanoidRootPart") then
		local offset = CFrame.Angles(0, currentCamAngleX, 0) * CFrame.new(0, 0, currentCameraDistance)
		camera.CFrame = CFrame.new(dummy.HumanoidRootPart.Position) * offset
	end
end)

