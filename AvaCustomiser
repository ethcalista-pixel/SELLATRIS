local activeCatBtn = nil

local function makeCatBtn(name, order)
	local btn = Instance.new("TextButton")
	btn.BackgroundColor3 = THEME.ItemBg
	btn.Text = name:upper()
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = THEME.TextDim
	btn.TextSize = 10
	btn.LayoutOrder = order
	btn.ZIndex = 6
	corner(btn, 8)
	local s = stroke(btn, THEME.Stroke, 1)
	btn.Parent = catGrid

	btn.MouseEnter:Connect(function()
		if activeCatBtn ~= btn then
			TweenService:Create(btn, TS_FAST, {TextColor3 = THEME.Text, BackgroundColor3 = THEME.ItemHover}):Play()
			TweenService:Create(s, TS_FAST, {Color = THEME.StrokeHot}):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if activeCatBtn ~= btn then
			TweenService:Create(btn, TS_FAST, {TextColor3 = THEME.TextDim, BackgroundColor3 = THEME.ItemBg}):Play()
			TweenService:Create(s, TS_FAST, {Color = THEME.Stroke}):Play()
		end
	end)
	return btn
end

local topBtn = makeCatBtn("Top",    1)
local botBtn = makeCatBtn("Bottom", 2)
local dihBtn = makeCatBtn("Dih",    3)
local puhBtn = makeCatBtn("Puh",    4)

local function setCatActive(btn)
	if activeCatBtn and activeCatBtn ~= btn then
		local old = activeCatBtn
		TweenService:Create(old, TS_FAST, {TextColor3 = THEME.TextDim, BackgroundColor3 = THEME.ItemBg}):Play()
		local os = old:FindFirstChildWhichIsA("UIStroke")
		if os then TweenService:Create(os, TS_FAST, {Color = THEME.Stroke}):Play() end
	end
	activeCatBtn = btn
	TweenService:Create(btn, TS_FAST, {TextColor3 = THEME.Text, BackgroundColor3 = THEME.ItemActive}):Play()
	local s = btn:FindFirstChildWhichIsA("UIStroke")
	if s then TweenService:Create(s, TS_FAST, {Color = THEME.Accent}):Play() end
end

local function clearCatActive()
	if activeCatBtn then
		TweenService:Create(activeCatBtn, TS_FAST, {TextColor3 = THEME.TextDim, BackgroundColor3 = THEME.ItemBg}):Play()
		local s = activeCatBtn:FindFirstChildWhichIsA("UIStroke")
		if s then TweenService:Create(s, TS_FAST, {Color = THEME.Stroke}):Play() end
		activeCatBtn = nil
	end
end

