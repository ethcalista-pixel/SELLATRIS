-- ── Panel expand / collapse ───────────────────────
local function setExpandedState(state, category)
	if state then
		rightTitleLbl.Text = categoryDisplayNames[category] or category:upper()

		local function populateOptions()
			for _, child in pairs(secScroll:GetChildren()) do
				if child:IsA("GuiObject") then child:Destroy() end
			end

			local options = {"Default"}
			local folder = morphsFolder:FindFirstChild(category)
			if folder then
				for _, mesh in pairs(folder:GetChildren()) do
					table.insert(options, mesh.Name)
				end
			end

			for idx, optName in ipairs(options) do
				local btn = Instance.new("TextButton")
				btn.Size = UDim2.new(1, -8, 0, 40)
				btn.BackgroundColor3 = THEME.ItemBg
				btn.Text = optName
				btn.Font = Enum.Font.GothamBold
				btn.TextColor3 = THEME.TextDim
				btn.TextSize = 11
				btn.ZIndex = 6
				btn.Parent = secScroll
				corner(btn, 8)
				local s = stroke(btn, THEME.Stroke, 1)

				btn.BackgroundTransparency = 1
				btn.TextTransparency = 1
				task.delay(idx * 0.03, function()
					if btn and btn.Parent then
						TweenService:Create(btn, TS_FAST, {BackgroundTransparency = 0}):Play()
						TweenService:Create(btn, TS_FAST, {TextTransparency = 0}):Play()
					end
				end)

				btn.MouseEnter:Connect(function()
					if pendingChanges[category] ~= optName then
						TweenService:Create(btn, TS_FAST, {BackgroundColor3 = THEME.ItemHover, TextColor3 = THEME.Text}):Play()
						TweenService:Create(s, TS_FAST, {Color = THEME.StrokeHot}):Play()
					end
					applyPreviewMorph(dummy, category, optName)
				end)
				btn.MouseLeave:Connect(function()
					local cur = pendingChanges[category] or "Default"
					if cur ~= optName then
						TweenService:Create(btn, TS_FAST, {BackgroundColor3 = THEME.ItemBg, TextColor3 = THEME.TextDim}):Play()
						TweenService:Create(s, TS_FAST, {Color = THEME.Stroke}):Play()
					end
					applyPreviewMorph(dummy, category, cur)
				end)
				btn.Activated:Connect(function()
					pendingChanges[category] = optName
					applyPreviewMorph(dummy, category, optName)
					updateSelectionVisuals(optName)
				end)
			end

			updateSelectionVisuals(pendingChanges[category] or "Default")
		end

		local cb = catBtnMap[category]
		if cb then setCatActive(cb) end

		if isExpanded then
			populateOptions()
		else
			if isTransitioning then return end
			isTransitioning = true
			isExpanded = true
			populateOptions()
			TweenService:Create(mainPanel, TS, {Size = UDim2.new(0, EXPAND_W, 0, PANEL_H)}):Play()
			task.delay(0.08, function()
				TweenService:Create(rightContainer, TS, {GroupTransparency = 0}):Play()
			end)
			task.delay(0.38, function() isTransitioning = false end)
		end
	else
		if not isExpanded or isTransitioning then return end
		isTransitioning = true
		isExpanded = false
		clearCatActive()
		TweenService:Create(rightContainer, TS_FAST, {GroupTransparency = 1}):Play()
		TweenService:Create(mainPanel, TS, {Size = UDim2.new(0, PANEL_W, 0, PANEL_H)}):Play()
		task.delay(0.35, function() isTransitioning = false end)
	end
end

