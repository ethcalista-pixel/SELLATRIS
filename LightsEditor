destroyHandles = function()
	if moveH  then moveH:Destroy();  moveH  = nil end
	if arcH   then arcH:Destroy();   arcH   = nil end
	if selBox then selBox:Destroy(); selBox = nil end
end

spawnHandles = function(lightObj)
	destroyHandles()
	if not lightObj then return end
	local part = lightObj.part

	selBox = mk("SelectionBox",gui,{
		Adornee=part, Color3=T.Accent,
		LineThickness=0.04, SurfaceTransparency=0.85, SurfaceColor3=T.Accent,
	})

	if handleMode == "Move" then
		local mh = mk("Handles",gui,{
			Adornee=part,
			Faces=Faces.new(Enum.NormalId.Front,Enum.NormalId.Back,Enum.NormalId.Left,Enum.NormalId.Right,Enum.NormalId.Top,Enum.NormalId.Bottom),
			Style=Enum.HandlesStyle.Movement,
		})
		moveH = mh
		local startCF, faceNorm = nil, nil
		mh.MouseButton1Down:Connect(function(face)
			startCF = part.CFrame
			local cf = part.CFrame
			local map = {
				[Enum.NormalId.Right]= cf.RightVector,[Enum.NormalId.Left]=-cf.RightVector,
				[Enum.NormalId.Top]= cf.UpVector,[Enum.NormalId.Bottom]=-cf.UpVector,
				[Enum.NormalId.Front]= cf.LookVector,[Enum.NormalId.Back]=-cf.LookVector,
			}
			faceNorm = map[face] or Vector3.new(0,1,0)
		end)
		mh.MouseDrag:Connect(function(_,dist)
			if not startCF then return end
			part.CFrame = CFrame.new(startCF.Position + faceNorm * dist)
				* CFrame.fromMatrix(Vector3.zero, startCF.XVector, startCF.YVector)
		end)
		mh.MouseButton1Up:Connect(function() startCF=nil; faceNorm=nil end)
	else
		local ah = mk("ArcHandles",gui,{
			Adornee=part,
			Axes=Axes.new(Enum.Axis.X,Enum.Axis.Y,Enum.Axis.Z),
		})
		arcH = ah
		local startCF = nil
		ah.MouseButton1Down:Connect(function() startCF = part.CFrame end)
		ah.MouseDrag:Connect(function(axis, angle)
			if not startCF then return end
			local wa
			if      axis==Enum.Axis.X then wa =  startCF.RightVector
			elseif  axis==Enum.Axis.Y then wa =  startCF.UpVector
			else                           wa = -startCF.LookVector
			end
			local pos = startCF.Position
			local piv = CFrame.new(pos)
			part.CFrame = (piv * CFrame.fromAxisAngle(wa, angle) * piv:Inverse()) * startCF
		end)
		ah.MouseButton1Up:Connect(function() startCF=nil end)
	end
end

local function makePropSld(label, minV, maxV, defV, fmt, order, onChange)
	local row=mk("Frame",propScroll,{Size=UDim2.new(1,0,0,52),BackgroundTransparency=1,ZIndex=6,LayoutOrder=order})
	local hdr=mk("Frame",row,{Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,ZIndex=6})
	mk("TextLabel",hdr,{
		Size=UDim2.new(1,-44,1,0),BackgroundTransparency=1,Text=label,
		TextColor3=T.TextMuted,TextSize=8,Font=Enum.Font.GothamBold,
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,
	})
	local vLbl=mk("TextLabel",hdr,{
		Size=UDim2.new(0,42,1,0),Position=UDim2.new(1,-42,0,0),
		BackgroundTransparency=1,Text=string.format(fmt,defV),
		TextColor3=T.AccentBright,TextSize=9,Font=Enum.Font.GothamBlack,
		TextXAlignment=Enum.TextXAlignment.Right,ZIndex=7,
	})
	local shell=mk("Frame",row,{
		Size=UDim2.new(1,0,0,28),Position=UDim2.new(0,0,0,20),
		BackgroundColor3=Color3.fromRGB(7,3,3),ZIndex=6,
	})
	corner(shell,6)
	mk("UIStroke",shell,{Color=Color3.fromRGB(40,18,18),Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
	local rail=mk("Frame",shell,{Size=UDim2.new(1,-16,0,2),Position=UDim2.new(0,8,0.5,-1),BackgroundColor3=Color3.fromRGB(45,18,18),ZIndex=7})
	corner(rail,1)
	local defA=math.clamp((defV-minV)/(maxV-minV),0,1)
	local rf=mk("Frame",rail,{Size=UDim2.new(defA,0,1,0),BackgroundColor3=T.Accent,ZIndex=8})
	corner(rf,1)
	mk("UIGradient",rf,{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T.AccentDeep),ColorSequenceKeypoint.new(0.5,T.AccentDark),ColorSequenceKeypoint.new(1,T.AccentBright)},Rotation=0})
	local ng=mk("Frame",shell,{Size=UDim2.new(0,10,1,-4),Position=UDim2.new(defA,-5,0,2),BackgroundColor3=T.Accent,BackgroundTransparency=0.72,ZIndex=8})
	corner(ng,4)
	local notch=mk("Frame",shell,{Size=UDim2.new(0,4,1,-10),Position=UDim2.new(defA,-2,0,5),BackgroundColor3=Color3.new(1,1,1),ZIndex=9})
	corner(notch,2)
	mk("UIGradient",notch,{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T.AccentBright),ColorSequenceKeypoint.new(1,T.Accent)},Rotation=90})
	local hitbox=mk("TextButton",shell,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10})
	local function setA(a)
		a=math.clamp(a,0,1)
		rf.Size=UDim2.new(a,0,1,0)
		ng.Position=UDim2.new(a,-5,0,2)
		notch.Position=UDim2.new(a,-2,0,5)
		vLbl.Text=string.format(fmt,minV+(maxV-minV)*a)
		onChange(minV+(maxV-minV)*a)
	end
	hitbox.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 then
			local a=math.clamp((inp.Position.X-shell.AbsolutePosition.X)/shell.AbsoluteSize.X,0,1)
			setA(a); dragging={track=shell,set=setA}
			TweenService:Create(ng,TS_FAST,{BackgroundTransparency=0.45}):Play()
		end
	end)
	hitbox.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 then TweenService:Create(ng,TS_FAST,{BackgroundTransparency=0.72}):Play() end
	end)
	hitbox.MouseEnter:Connect(function()
		TweenService:Create(ng,TS_FAST,{BackgroundTransparency=0.55}):Play()
		TweenService:Create(vLbl,TS_FAST,{TextColor3=T.Text}):Play()
	end)
	hitbox.MouseLeave:Connect(function()
		TweenService:Create(ng,TS_FAST,{BackgroundTransparency=0.72}):Play()
		TweenService:Create(vLbl,TS_FAST,{TextColor3=T.AccentBright}):Play()
	end)
	return setA
end

