RunService.RenderStepped:Connect(function(dt)
	for _, p in ipairs(particles) do
		p.y -= p.speed * dt
		if p.y < -0.1 then p.y=1.08; p.baseX=rng:NextNumber(0,1) end
		p.gui.Position = UDim2.new(p.baseX + math.sin(tick()*p.freq+p.seed)*p.amp, 0, p.y, 0)
	end
	for _,l in ipairs(lightList) do
		if l.part and l.part.Parent then
			l.part.Color = l.light.Color
			if l.rowDot   then l.rowDot.BackgroundColor3 = l.light.Color end
			if l.billboard then l.billboard.Text = l.name end
		end
	end
end)
