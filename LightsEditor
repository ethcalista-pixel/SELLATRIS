local function mk(cls, parent, props)
	local i = Instance.new(cls)
	if parent then i.Parent = parent end
	if props then for k,v in pairs(props) do i[k]=v end end
	return i
end
local function corner(p, r) return mk("UICorner", p, {CornerRadius=UDim.new(0,r or 8)}) end
local function stroke(p, c, t) return mk("UIStroke", p, {Color=c or T.Stroke, Thickness=t or 1, ApplyStrokeMode=Enum.ApplyStrokeMode.Border}) end
local function grad(p, c0, c1, r) return mk("UIGradient", p, {Color=ColorSequence.new{ColorSequenceKeypoint.new(0,c0), ColorSequenceKeypoint.new(1,c1)}, Rotation=r or 90}) end

