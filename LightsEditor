				TextXAlignment=Enum.TextXAlignment.Left,
				ClearTextOnFocus=false, ZIndex=9,
			})
			corner(tb,4); stroke(tb,T.Accent,1)
			tb:CaptureFocus()
			tb.FocusLost:Connect(function()
				local n = tb.Text ~= "" and tb.Text or lightObj.name
				lightObj.name = n
				nameLbl.Text = n
				if selectedId == lightObj.id then rightNameLbl.Text = n:upper() end
				if lightObj.billboard then lightObj.billboard.Text = n end
				nameLbl.Visible = true
				tb:Destroy()
			end)
		else
			clickTimer = task.delay(0.36, function()
				clickTimer = nil
				selectLight(lightObj.id)
			end)
		end
		lastClick = now
	end)

	row.MouseEnter:Connect(function()
		if selectedId ~= lightObj.id then
			TweenService:Create(row,TS_FAST,{BackgroundColor3=T.ItemHover}):Play()
			TweenService:Create(rs,TS_FAST,{Color=T.StrokeHot}):Play()
			TweenService:Create(nameLbl,TS_FAST,{TextColor3=T.Text}):Play()
		end
	end)
	row.MouseLeave:Connect(function()
		if selectedId ~= lightObj.id then
			TweenService:Create(row,TS_FAST,{BackgroundColor3=T.ItemBg}):Play()
			TweenService:Create(rs,TS_FAST,{Color=T.Stroke}):Play()
			TweenService:Create(nameLbl,TS_FAST,{TextColor3=T.TextDim}):Play()
		end
	end)

	table.insert(lightList, lightObj)
end

local function spawnLight(templatePart)
	local lightInst = nil
	for _,c in ipairs(templatePart:GetChildren()) do
		if c:IsA("PointLight") or c:IsA("SpotLight") or c:IsA("SurfaceLight") then
			lightInst = c:Clone(); break
		end
	end
	if not lightInst then return end

	lightCounts[templatePart.Name] = (lightCounts[templatePart.Name] or 0) + 1
	local name = templatePart.Name .. " " .. lightCounts[templatePart.Name]

	local spawnCF = workspace.CurrentCamera.CFrame * CFrame.new(0,0,-8)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		spawnCF = char.HumanoidRootPart.CFrame * CFrame.new(0,2,-5)
	end

	local part = mk("Part", lightContainer, {
		Shape=Enum.PartType.Ball,
		Size=Vector3.new(0.4,0.4,0.4),
		CFrame=spawnCF,
		Anchored=true,
		CanCollide=false,
		CanQuery=true,
		CanTouch=false,
		CastShadow=false,
		Material=Enum.Material.Neon,
		Color=lightInst.Color,
		Name=name,
	})

	part.LocalTransparencyModifier = panelOpen and 0 or 1

	local bb = mk("BillboardGui",part,{
		Size=UDim2.fromOffset(130,22),
		StudsOffset=Vector3.new(0,0.7,0),
		AlwaysOnTop=true,
		Enabled=panelOpen,
	})
	local bbLbl = mk("TextLabel",bb,{
		Size=UDim2.fromScale(1,1),
		BackgroundTransparency=1,
		Text=name,
		TextColor3=Color3.new(1,1,1),
		TextSize=11, Font=Enum.Font.GothamBlack,
		TextStrokeTransparency=0.35,
	})

	lightInst.Parent = part

	local lightObj = {
		id=nextId(), name=name,
		part=part, light=lightInst, type=lightInst.ClassName,
		billboard=bbLbl, billboardGui=bb,
		rowDot=nil, rowFrame=nil, nameLbl=nil,
	}

	addLightRow(lightObj)
	task.defer(function() selectLight(lightObj.id) end)
end

