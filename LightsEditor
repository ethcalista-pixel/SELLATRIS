UserInputService.InputBegan:Connect(function(inp, gpe)
	if not panelOpen or gpe then return end
	if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	local parts = {}
	for _,l in ipairs(lightList) do if l.part then table.insert(parts,l.part) end end
	if #parts == 0 then return end
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Include
	params.FilterDescendantsInstances = parts
	local mouse = UserInputService:GetMouseLocation()
	local ray = workspace.CurrentCamera:ScreenPointToRay(mouse.X, mouse.Y)
	local result = workspace:Raycast(ray.Origin, ray.Direction * 500, params)
	if result then
		for _,l in ipairs(lightList) do
			if l.part == result.Instance then selectLight(l.id); return end
		end
	end
end)

