buildProperties = function(lightObj)
	for _,c in pairs(propScroll:GetChildren()) do
		if c:IsA("GuiObject") then c:Destroy() end
	end
	if not lightObj then return end

	local light = lightObj.light
	local ltype = lightObj.type
	rightNameLbl.Text = lightObj.name:upper()

	-- Type badge
	local badge=mk("Frame",propScroll,{Size=UDim2.new(1,0,0,28),BackgroundColor3=T.ItemBg,ZIndex=6,LayoutOrder=1})
	corner(badge,7); stroke(badge,T.Stroke,1)
	local bdot=mk("Frame",badge,{Size=UDim2.new(0,6,0,6),Position=UDim2.new(0,10,0.5,-3),BackgroundColor3=T.Accent,ZIndex=7})
	corner(bdot,3)
	mk("TextLabel",badge,{
		Size=UDim2.new(1,-22,1,0),Position=UDim2.new(0,22,0,0),
		BackgroundTransparency=1,Text=ltype:upper(),
		TextColor3=T.TextDim,TextSize=9,Font=Enum.Font.GothamBlack,
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,
	})

	makePropSec("PROPERTIES", 10)
	makePropSld("BRIGHTNESS", 0, 10, light.Brightness, "%.2f", 11, function(v) light.Brightness=v end)
	makePropSld("RANGE",      0, 100, light.Range,      "%.0f", 12, function(v) light.Range=v end)

	makePropSec("COLOR", 20)
	local function updateCol(r,g,b)
		local c=Color3.new(math.clamp(r,0,1),math.clamp(g,0,1),math.clamp(b,0,1))
		light.Color=c
		if lightObj.rowDot then lightObj.rowDot.BackgroundColor3=c end
	end
	makePropSld("RED",   0,1, light.Color.R, "%.2f", 21, function(v) updateCol(v, light.Color.G, light.Color.B) end)
	makePropSld("GREEN", 0,1, light.Color.G, "%.2f", 22, function(v) updateCol(light.Color.R, v, light.Color.B) end)
	makePropSld("BLUE",  0,1, light.Color.B, "%.2f", 23, function(v) updateCol(light.Color.R, light.Color.G, v) end)

	makePropSec("OPTIONS", 30)
	makePropTog("CAST SHADOWS", light.Shadows, 31, function(v) light.Shadows=v end)

	if ltype == "SpotLight" or ltype == "SurfaceLight" then
		makePropSec("DIRECTIONAL", 40)
		makePropSld("ANGLE", 0, 180, light.Angle, "%.0f°", 41, function(v) light.Angle=v end)

		local faceNames = {"Top","Bottom","Front","Back","Left","Right"}
		local faceContainer=mk("Frame",propScroll,{Size=UDim2.new(1,0,0,62),BackgroundTransparency=1,ZIndex=6,LayoutOrder=42})
		mk("TextLabel",faceContainer,{
			Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,Text="FACE",
			TextColor3=T.TextMuted,TextSize=8,Font=Enum.Font.GothamBold,
			TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,
		})
		local faceGrid=mk("Frame",faceContainer,{Size=UDim2.new(1,0,0,42),Position=UDim2.new(0,0,0,18),BackgroundTransparency=1,ZIndex=6})
		mk("UIGridLayout",faceGrid,{
			CellSize=UDim2.new(1/3,-4,0,18), CellPadding=UDim2.new(0,5,0,5),
			SortOrder=Enum.SortOrder.LayoutOrder,
		})
		for i,fn in ipairs(faceNames) do
			local isActive = light.Face == Enum.NormalId[fn]
			local fb=mk("TextButton",faceGrid,{
				BackgroundColor3=isActive and T.ItemActive or T.ItemBg,
				Text=fn:upper(),TextColor3=isActive and T.Text or T.TextMuted,
				TextSize=7,Font=Enum.Font.GothamBold,ZIndex=7,LayoutOrder=i,
			})
			corner(fb,5); local fs=stroke(fb,isActive and T.Accent or T.Stroke,1)
			fb.MouseButton1Click:Connect(function()
				light.Face=Enum.NormalId[fn]
				for _,c in pairs(faceGrid:GetChildren()) do
					if c:IsA("TextButton") then
						local a=c.Text==fn:upper()
						TweenService:Create(c,TS_FAST,{BackgroundColor3=a and T.ItemActive or T.ItemBg,TextColor3=a and T.Text or T.TextMuted}):Play()
						local cs=c:FindFirstChildWhichIsA("UIStroke")
						if cs then TweenService:Create(cs,TS_FAST,{Color=a and T.Accent or T.Stroke}):Play() end
					end
				end
			end)
		end
	end
end

setExpanded = function(state, id)
	if state then
		local l = findLight(id or selectedId)
		if l then buildProperties(l) end
		if isExpanded then return end
		if isTrans then return end
		isTrans=true; isExpanded=true
		TweenService:Create(mainPanel,TS,{Size=UDim2.new(0,EXPAND_W,0,PANEL_H)}):Play()
		task.delay(0.08,function() TweenService:Create(rightCanvas,TS,{GroupTransparency=0}):Play() end)
		task.delay(0.38,function() isTrans=false end)
	else
		if not isExpanded or isTrans then return end
		isTrans=true; isExpanded=false
		TweenService:Create(rightCanvas,TS_FAST,{GroupTransparency=1}):Play()
		TweenService:Create(mainPanel,TS,{Size=UDim2.new(0,PANEL_W,0,PANEL_H)}):Play()
		task.delay(0.35,function() isTrans=false end)
	end
end

selectLight = function(id)
	if selectedId then
		local old = findLight(selectedId)
		if old and old.rowFrame then
			local os=old.rowFrame:FindFirstChildWhichIsA("UIStroke")
			if os then TweenService:Create(os,TS_FAST,{Color=T.Stroke}):Play() end
			TweenService:Create(old.rowFrame,TS_FAST,{BackgroundColor3=T.ItemBg}):Play()
			local nl=old.rowFrame:FindFirstChildWhichIsA("TextLabel")
			if nl then TweenService:Create(nl,TS_FAST,{TextColor3=T.TextDim}):Play() end
		end
	end
	selectedId = id
	if id then
		local l = findLight(id)
		if l and l.rowFrame then
			local s=l.rowFrame:FindFirstChildWhichIsA("UIStroke")
			if s then TweenService:Create(s,TS_FAST,{Color=T.Accent}):Play() end
			TweenService:Create(l.rowFrame,TS_FAST,{BackgroundColor3=T.ItemActive}):Play()
		end
		setExpanded(true, id)
		if l then spawnHandles(l) end
	else
		destroyHandles()
		setExpanded(false)
	end
end

