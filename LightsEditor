	delBtn.MouseEnter:Connect(function() TweenService:Create(delBtn,TS_FAST,{BackgroundColor3=T.AccentDark,TextColor3=T.Text}):Play() end)
	delBtn.MouseLeave:Connect(function() TweenService:Create(delBtn,TS_FAST,{BackgroundColor3=T.Stroke,TextColor3=T.TextMuted}):Play() end)
	delBtn.MouseButton1Click:Connect(function()
		local id = lightObj.id
		if selectedId == id then selectLight(nil) end
		if lightObj.part and lightObj.part.Parent then lightObj.part:Destroy() end
		row:Destroy()
		for i,l in ipairs(lightList) do
			if l.id == id then table.remove(lightList,i); break end
		end
		if #lightList == 0 then emptyLbl.Visible = true end
	end)

	-- Single click = select; double click = rename
	local lastClick = 0
	local clickTimer = nil
	row.MouseButton1Click:Connect(function()
		local now = tick()
		if now - lastClick < 0.35 then
			if clickTimer then task.cancel(clickTimer); clickTimer=nil end
			nameLbl.Visible = false
			local tb=mk("TextBox",row,{
				Size=UDim2.new(1,-72,1,0), Position=UDim2.new(0,22,0,0),
				BackgroundColor3=T.ItemBg, Text=lightObj.name,
